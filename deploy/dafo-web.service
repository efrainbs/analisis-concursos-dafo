[Unit]
Description=DAFO — Estímulos para el audiovisual peruano
After=network.target

[Service]
Type=simple
User=%USER%
WorkingDirectory=%APP_DIR%
Environment="PATH=%APP_DIR%/.venv/bin"
ExecStart=%APP_DIR%/.venv/bin/gunicorn -w 2 -b 127.0.0.1:8501 server.server:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
